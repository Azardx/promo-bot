# ==============================================================================
# Configurações do PromoBot
# ==============================================================================

# ------------------------------------------------------------------------------
# Telegram (Obrigatório)
# ------------------------------------------------------------------------------
# Token do bot obtido no @BotFather
BOT_TOKEN=seu_token_aqui

# ID do administrador (para receber erros e usar comandos /stats, /force)
ADMIN_ID=123456789

# ID do canal ou grupo onde as promoções serão enviadas
# Para canais públicos use @nome_do_canal
# Para canais/grupos privados use o ID numérico (ex: -100123456789)
CHANNEL_ID=@seu_canal_de_promos
GROUP_ID=

# ------------------------------------------------------------------------------
# Comportamento e Scraping
# ------------------------------------------------------------------------------
# Intervalo entre os ciclos de busca (em segundos)
SCRAPE_INTERVAL=120

# Timeout para requisições HTTP (em segundos)
HTTP_TIMEOUT=20

# Delay entre o envio de mensagens no Telegram (para evitar rate limit)
BROADCAST_DELAY=0.5

# Máximo de promoções enviadas por ciclo
MAX_PROMOS_PER_CYCLE=30

# Lojas habilitadas (separadas por vírgula)
# Fontes confiáveis: kabum, promobit, pelando (funcionam sem proxy)
# Fontes com proteção anti-bot: amazon, shopee, aliexpress (podem precisar de curl_cffi ou proxy)
# Opções: shopee, aliexpress, amazon, pelando, promobit, kabum
ENABLED_SCRAPERS=kabum,promobit,pelando,aliexpress,amazon,shopee

# ------------------------------------------------------------------------------
# Filtros
# ------------------------------------------------------------------------------
# Preço mínimo e máximo para aceitar uma oferta
MIN_PRICE=1.0
MAX_PRICE=50000.0

# Palavras que bloqueiam a oferta (separadas por vírgula)
BLOCKED_KEYWORDS=capinha,película,adesivo,suporte celular

# Palavras que dão prioridade/pontuação extra (separadas por vírgula)
PRIORITY_KEYWORDS=ssd,rtx,notebook,iphone,airpods,galaxy,playstation,xbox,monitor,gpu

# ------------------------------------------------------------------------------
# Proxies (Opcional)
# ------------------------------------------------------------------------------
# Habilitar uso de proxies (True/False)
USE_PROXIES=False

# Arquivo com a lista de proxies (um por linha)
PROXY_LIST_FILE=proxies.txt

# ------------------------------------------------------------------------------
# Sistema
# ------------------------------------------------------------------------------
# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
